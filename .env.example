RESEND_API_KEY=re_xxxxxxxxx
ALERT_EMAIL_TO=contact.sahajpreetsingh@gmail.com

# --- DigitalOcean Droplet Deploy ---
DROPLET_IP = # Your DigitalOcean Droplet's public IP address
DROPLET_USER= # Your Droplet's SSH username (e.g., root)
DROPLET_PASS= # Your Droplet's SSH password (or use SSH key authentication for better security)

# --- Discord Alert Webhook ---
DISCORD_WEBHOOK_URL= # Create a webhook in your Discord channel and paste the URL here